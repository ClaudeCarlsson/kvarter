{
  "name": "housing-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "bun test src/",
    "test:analytics": "cd analytics && uv run pytest --cov",
    "test:all": "bun run test && bun run test:analytics",
