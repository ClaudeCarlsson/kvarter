# Booli GraphQL API (required)
BOOLI_GRAPHQL_URL=https://api.booli.se/graphql

# Redis (local Docker)
REDIS_URL=redis://localhost:6379

# Cache
CACHE_ENABLED=true

# Data source: 'booli-graphql' | 'playwright' | 'scraper' | 'hemnet'
DATA_SOURCE=playwright

# SBAB API (for mortgage rate data)
SBAB_BEARER_TOKEN=
SBAB_BASE_URL=https://developer.sbab.se/sandbox
