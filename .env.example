# Booli GraphQL API (required)
BOOLI_GRAPHQL_URL=https://api.booli.se/graphql

# Redis (local Docker)
REDIS_URL=redis://localhost:6379

# Cache
CACHE_ENABLED=true

# Data source: 'booli-graphql' (default) or 'scraper'
DATA_SOURCE=booli-graphql

# SBAB API (for mortgage rate data)
SBAB_BEARER_TOKEN=
SBAB_BASE_URL=https://developer.sbab.se/sandbox
